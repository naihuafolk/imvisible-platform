# ============================================================
# RankPilot AI / ImVisible — ตัวอย่างการตั้งค่า (คัดลอกเป็น .env แล้วใส่คีย์จริง)
# แต่ละบรรทัดบอกว่า "ต่อกับใคร / เอาคีย์จากไหน"  ·  ค่าว่าง = ปิดฟีเจอร์นั้น (ระบบยังรันได้)
# ============================================================

# ---------- 0) โครงสร้างพื้นฐาน + Auth ----------
# ว่าง = รันแบบไม่มี DB (auth/บันทึกผลจะใช้ไม่ได้ — ต้องตั้งเพื่อใช้งานจริง)
DATABASE_URL=postgresql+asyncpg://rankpilot:rankpilot@localhost:5432/rankpilot
REDIS_URL=redis://localhost:6379/0
# prod ต้องตั้งค่าจริงยาว ≥ 32 ตัว (สุ่ม) — สำคัญ: api + worker ต้องใช้ค่าเดียวกัน (crypto)
JWT_SECRET=dev-only-secret-change-me-in-production-please-32b
JWT_EXPIRE_HOURS=168

# ---------- 0b) Production hardening ----------
APP_ENV=dev                  # dev | prod  (prod = บังคับ JWT_SECRET จริง + ส่ง HSTS)
RATE_LIMIT_PER_MIN=30        # จำกัดคำขอ auth ต่อ IP ต่อนาที (กัน brute-force)
SENTRY_DSN=                  # ตั้ง = เปิด error monitoring (ต้องลง sentry-sdk)
# URL ของแดชบอร์ด (ใช้ทำ redirect หลังจ่ายเงิน Stripe + callback OAuth)
APP_BASE_URL=http://localhost:8080
# อีเมลแอดมิน/เทสต์ (คั่นด้วย ,) → ได้แพ็กเกจ business อัตโนมัติ โดยไม่ต้องจ่ายเงิน (ใช้ทดสอบแบรนด์ตัวเอง)
ADMIN_EMAILS=

# ---------- 1) SERP API — อันดับ Google (จำเป็นต่อการวัดผล) ----------
# DataForSEO → https://app.dataforseo.com (Dashboard > API Access) · Basic Auth
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
SERP_LOCATION_CODE=2764      # ไทย
SERP_LANGUAGE_CODE=th

# ---------- 2) Google Search Console (เสริม) ----------
# Google Cloud → เปิด "Search Console API" + OAuth Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=        # หรือให้ลูกค้ากด "เชื่อม Google" ในแอป (ใช้ค่าด้านล่าง)
# ต้องตรงกับ Authorized redirect URI ใน Google Console เป๊ะ ๆ
GOOGLE_REDIRECT_URI=         # เช่น https://app.imvisible.tech/api/oauth/google/callback

# ---------- 3) LLM — ผลิต/วิเคราะห์คอนเทนต์ (จำเป็นอย่างน้อย 1 เจ้า) ----------
ANTHROPIC_API_KEY=           # https://console.anthropic.com (แนะนำสำหรับงานเขียน)
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=              # https://platform.openai.com/api-keys
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=              # https://aistudio.google.com/app/apikey
GEMINI_MODEL=gemini-2.5-flash

# ---------- 4) AI Citation — Prompt Sampling (เสริม) ----------
# ใช้คีย์ OpenAI/Gemini/Anthropic ด้านบนได้ + Perplexity เพิ่ม
PERPLEXITY_API_KEY=          # https://www.perplexity.ai/settings/api
PERPLEXITY_MODEL=sonar

# ---------- 5) เผยแพร่ (managed hosting ใช้ได้เลยไม่ต้องมีคีย์) ----------
# WordPress (ถ้าลูกค้าจะเผยแพร่ขึ้นเว็บตัวเอง) — หรือให้ลูกค้าใส่คีย์ตัวเองในแอป
WORDPRESS_BASE_URL=          # เช่น https://abc-beautyclinic.com
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# ---------- 5b) Managed Hosting (โฮสต์บล็อกลูกค้าให้เอง) ----------
MANAGED_BASE_DOMAIN=imvisible.tech   # เสิร์ฟที่ {slug}.imvisible.tech และ /blog/{slug}
MANAGED_SCHEME=https

# ---------- 6) IndexNow — แจ้ง index ทันที (เสริม) ----------
INDEXNOW_KEY=                # สุ่ม 32 hex แล้ววางไฟล์ {key}.txt ที่ root ของเว็บ
INDEXNOW_HOST=               # เช่น imvisible.tech

# ---------- 7) GA4 + PageSpeed (เสริม) ----------
GA4_PROPERTY_ID=
PAGESPEED_API_KEY=           # PageSpeed Insights (ไม่มีก็ใช้ได้ แต่ rate-limited)

# ---------- 8) LINE — แจ้งเตือน (เสริม) ----------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_DEFAULT_TO=

# ---------- 9) ModelArk (BytePlus) — Seedream รูป / Seedance วิดีโอ (เสริม) ----------
ARK_API_KEY=
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
ARK_IMAGE_MODEL=dola-seedream-5-0-pro-260628
ARK_VIDEO_MODEL=

# ---------- 10) Email — รายงานรายสัปดาห์/แจ้งเตือน (เสริม) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=                   # เช่น "ImVisible <no-reply@imvisible.tech>"

# ---------- 11) Billing (Stripe) — subscription จริง (ใส่ทีหลังตอนพร้อมขาย) ----------
# ระบบรันได้เต็มโดยไม่ต้องมีคีย์นี้ (ปุ่มจ่ายเงินจะยังใช้ไม่ได้จนกว่าจะตั้งค่า)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=            # price_id ของแพ็กเกจ Pro
STRIPE_PRICE_BUSINESS=      # price_id ของแพ็กเกจ Business

# ---------- ทั่วไป ----------
CORS_ORIGINS=*
