# ============================================================
# RankPilot AI — ตัวอย่างการตั้งค่า (คัดลอกเป็น .env แล้วใส่คีย์จริง)
# แต่ละบรรทัดบอกว่า "ต่อกับใคร / เอาคีย์จากไหน"
# ============================================================

# ---------- 1) SERP API — อันดับ Google (จำเป็น) ----------
# ผู้ให้บริการ: DataForSEO  → https://app.dataforseo.com (Dashboard > API Access)
# ใช้ Basic Auth ด้วย login/password ของบัญชี DataForSEO
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# ค่าเริ่มต้นประเทศไทย/ภาษาไทย
SERP_LOCATION_CODE=2764
SERP_LANGUAGE_CODE=th

# ---------- 2) Google Search Console (จำเป็น) ----------
# ผู้ให้บริการ: Google Cloud → https://console.cloud.google.com
# เปิด "Search Console API", สร้าง OAuth Client (Desktop) แล้วขอ refresh_token
# (scope: https://www.googleapis.com/auth/webmasters.readonly)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ---------- 3) LLM — ผลิต/วิเคราะห์คอนเทนต์ (จำเป็นอย่างน้อย 1 เจ้า) ----------
# Anthropic (Claude) → https://console.anthropic.com  (แนะนำสำหรับงานเขียน)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# OpenAI (GPT)  → https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Google Gemini → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---------- 4) AI Citation — Prompt Sampling (จำเป็น) ----------
# ใช้คีย์ OpenAI/Gemini ด้านบน + Perplexity เพิ่ม
# Perplexity → https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# ---------- 5) เผยแพร่ (จำเป็นอย่างน้อย 1 ปลายทาง) ----------
# WordPress: สร้าง "Application Password" ที่ Users > Profile ของเว็บ
WORDPRESS_BASE_URL=          # เช่น https://abc-beautyclinic.com
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
# Webflow (ถ้าใช้) → https://webflow.com/dashboard (Site settings > Apps & integrations)
WEBFLOW_API_TOKEN=
WEBFLOW_COLLECTION_ID=

# ---------- 6) IndexNow — แจ้ง index ทันที (เสริม) ----------
# สร้างคีย์เอง (สุ่ม 32 hex) แล้ววางไฟล์ {key}.txt ไว้ที่ root ของเว็บ
INDEXNOW_KEY=
INDEXNOW_HOST=              # เช่น abc-beautyclinic.com

# ---------- 7) GA4 — วัด Conversion/ROI (เสริม) ----------
GA4_PROPERTY_ID=

# ---------- 8) LINE — แจ้งเตือน (เสริม) ----------
# หมายเหตุ: LINE Notify ปิดบริการแล้ว (31 มี.ค. 2025) → ใช้ LINE Messaging API แทน
# สร้าง Channel ที่ https://developers.line.biz > Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_DEFAULT_TO=            # userId/groupId ปลายทาง

# ---------- ทั่วไป ----------
CORS_ORIGINS=*
